{
  "name": "entrance-pass-android",
  "version": "1.0.0",
  "private": true,
  "description": "Android shell for Entrance Pass System (WebView + Capacitor)",
  "scripts": {
    "copy:www": "node -e \"require('fs').copyFileSync('index.html','www/index.html')\"",
    "sync": "npm run copy:www && cap sync",
    "open:android": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/core": "^7.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0"
  }
}
